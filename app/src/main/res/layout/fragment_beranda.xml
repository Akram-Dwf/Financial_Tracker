<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <!-- Header Background (Curved) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_curved_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Header Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dashboard Keuangan"
                        android:textColor="@color/md_theme_on_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_trash"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        style="@style/Widget.Material3.Button.IconButton"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="@color/md_theme_on_primary"
                        app:iconSize="24dp"
                        android:contentDescription="Tempat Sampah" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Pantau pemasukan dan pengeluaran usaha Anda"
                    android:textColor="@color/md_theme_on_primary"
                    android:alpha="0.85"
                    android:textSize="14sp" />

                <!-- Month Filter Chip -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bulan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/bulan_ini"
                    android:textColor="@color/md_theme_primary"
                    app:chipBackgroundColor="@color/md_theme_on_primary"
                    app:chipIcon="@drawable/ic_calendar"
                    app:chipIconTint="@color/md_theme_primary"
                    app:closeIconEnabled="false" />
            </LinearLayout>

            <!-- Summary Cards Grid (2x2) overlapping the header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-30dp"
                android:paddingHorizontal="12dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Card 1: Total Uang Masuk -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/bg_icon_circle"
                                android:backgroundTint="@color/card_beranda_pesanan"
                                android:padding="6dp"
                                android:contentDescription="@string/total_uang_masuk"
                                android:src="@drawable/ic_money_up"
                                app:tint="@color/md_theme_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_uang_masuk"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_pesanan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_income"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 2: Total Belanja Bahan -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/bg_icon_circle"
                                android:backgroundTint="@color/card_beranda_belanja"
                                android:padding="10dp"
                                android:contentDescription="@string/total_belanja_bahan"
                                android:src="@drawable/ic_shopping_cart"
                                app:tint="@color/color_warning" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_belanja_bahan"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_belanja"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_warning"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Card 3: Total Biaya Lain -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/bg_icon_circle"
                                android:backgroundTint="@color/card_beranda_biaya"
                                android:padding="6dp"
                                android:contentDescription="@string/total_biaya_lain"
                                android:src="@drawable/ic_money_down"
                                app:tint="@color/color_expense" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_biaya_lain"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_biaya"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_expense"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card 4: Keuntungan Bersih -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/bg_icon_circle"
                                android:backgroundTint="@color/card_beranda_untung"
                                android:padding="10dp"
                                android:contentDescription="@string/keuntungan_bersih"
                                android:src="@drawable/ic_profit"
                                app:tint="@color/color_profit" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/keuntungan_bersih"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_keuntungan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_profit"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 3: Saldo Kas Aktual -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/md_theme_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/card_beranda_pesanan"
                            android:padding="10dp"
                            android:contentDescription="Uang Kas Aktual"
                            android:src="@drawable/ic_wallet"
                            app:tint="@color/md_theme_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saldo Kas Aktual (Cash &amp; Transfer)"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_saldo_kas_aktual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/md_theme_primary"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions Row -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aksi Cepat"
                    android:textColor="@color/md_theme_on_surface"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginHorizontal="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- Action Pesanan -->
                    <LinearLayout
                        android:id="@+id/btn_action_pesanan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/card_beranda_pesanan"
                            android:src="@drawable/ic_add"
                            app:tint="@color/md_theme_primary"
                            android:padding="12dp"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pesanan"
                            android:textSize="12sp"
                            android:textColor="@color/md_theme_on_surface"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Action Belanja -->
                    <LinearLayout
                        android:id="@+id/btn_action_belanja"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/card_beranda_belanja"
                            android:src="@drawable/ic_add"
                            app:tint="@color/color_warning"
                            android:padding="12dp"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belanja"
                            android:textSize="12sp"
                            android:textColor="@color/md_theme_on_surface"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Action Biaya -->
                    <LinearLayout
                        android:id="@+id/btn_action_biaya"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/card_beranda_biaya"
                            android:src="@drawable/ic_add"
                            app:tint="@color/color_expense"
                            android:padding="12dp"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biaya"
                            android:textSize="12sp"
                            android:textColor="@color/md_theme_on_surface"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Smart Insight Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_insight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:background="@drawable/bg_gradient_insight"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_idea"
                            app:tint="@color/md_theme_on_primary_container"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tv_insight_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Belum ada data cukup untuk dianalisis bulan ini."
                            android:textColor="@color/md_theme_on_primary_container"
                            android:textSize="14sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Section Utang & Piutang -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Utang &amp; Piutang Usaha (Semua Periode)"
                    android:textColor="@color/md_theme_on_surface"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginHorizontal="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Card Piutang -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_piutang_beranda"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Piutang Usaha"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_piutang_beranda"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_warning"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Kelola ›"
                                android:textSize="11sp"
                                android:textColor="@color/md_theme_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card Utang -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_utang_beranda"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/md_theme_surface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="4dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Utang Usaha"
                                android:textColor="@color/md_theme_on_surface_variant"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_utang_beranda"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Rp 0"
                                android:textColor="@color/color_expense"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Kelola ›"
                                android:textSize="11sp"
                                android:textColor="@color/md_theme_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tip: Geser halaman ke kiri atau kanan untuk berpindah menu."
                android:textAlignment="center"
                android:textColor="@color/md_theme_on_surface_variant"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:textSize="13sp"
                android:alpha="0.7"/>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
