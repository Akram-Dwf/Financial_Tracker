<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_background">

    <!-- STICKY HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:background="@color/md_theme_background"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/laporan_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_primary" />

            <ImageButton
                android:id="@+id/btn_cetak_laporan"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_print"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/md_theme_primary"
                android:contentDescription="Cetak Laporan" />
        </LinearLayout>

        <!-- Month Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btn_prev_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_left"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/md_theme_primary"
                android:contentDescription="Bulan Sebelumnya" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_bulan_laporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="@string/bulan_ini"
                android:textSize="16sp"
                android:textStyle="bold"
                app:chipBackgroundColor="@color/md_theme_primary_container"
                app:chipIcon="@drawable/ic_calendar"
                app:chipIconTint="@color/md_theme_on_primary_container"
                app:chipMinHeight="48dp" />

            <ImageButton
                android:id="@+id/btn_next_month"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_chevron_right"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/md_theme_primary"
                android:contentDescription="Bulan Berikutnya" />
        </LinearLayout>

    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Card (Untung / Rugi) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_beranda_untung">

                <LinearLayout
                    android:id="@+id/layout_status_bg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center"
                    android:background="@drawable/bg_gradient_status_untung">

                    <ImageView
                        android:id="@+id/iv_status_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_trending_up"
                        app:tint="@color/color_profit" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bulan ini UNTUNG Rp 0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_profit"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Chart Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Grafik Alokasi Dana"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_primary"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart_laporan"
                        android:layout_width="match_parent"
                        android:layout_height="280dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section A: Pendapatan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_wallet"
                            app:tint="@color/md_theme_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/uang_masuk"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hasil Pesanan / Penjualan"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_pendapatan_penjualan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/md_theme_surface_variant"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL UANG MASUK"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_income" />
                        <TextView
                            android:id="@+id/tv_total_uang_masuk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_income" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section B: Biaya Bahan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_shopping_cart"
                            app:tint="@color/md_theme_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/biaya_bahan"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belanja Bahan Baku"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_biaya_bahan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/md_theme_surface_variant"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL BIAYA BAHAN"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_expense" />
                        <TextView
                            android:id="@+id/tv_total_biaya_bahan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_expense" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section C: Biaya Operasional -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_receipt"
                            app:tint="@color/md_theme_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/biaya_operasional"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biaya Operasional Lain"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_biaya_operasional"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/md_theme_surface_variant"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL BIAYA OPERASIONAL"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_expense" />
                        <TextView
                            android:id="@+id/tv_total_biaya_operasional"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/color_expense" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section D: Perhitungan HPP -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_calculate"
                            app:tint="@color/md_theme_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/hpp"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biaya Bahan Baku"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_hpp_bahan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biaya Operasional"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_hpp_operasional"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/md_theme_surface_variant"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_hpp"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_total_hpp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section E: Keuntungan -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_variant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_savings"
                            app:tint="@color/md_theme_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/keuntungan"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_theme_primary" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Uang Masuk"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_total_masuk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total HPP"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_total_hpp_final"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/md_theme_outline"
                        android:layout_marginVertical="8dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KEUNTUNGAN BERSIH"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/md_theme_on_surface" />
                        <TextView
                            android:id="@+id/tv_keuntungan_bersih"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Rp 0"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/md_theme_on_surface" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Margin Keuntungan Bersih"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface_variant" />
                        <TextView
                            android:id="@+id/tv_margin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0%"
                            android:textSize="14sp"
                            android:textColor="@color/md_theme_on_surface_variant" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cetak Laporan Button Besar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cetak_laporan_besar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="Cetak &amp; Bagikan PDF"
                android:textSize="16sp"
                app:icon="@drawable/ic_print"
                app:iconGravity="textStart"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
