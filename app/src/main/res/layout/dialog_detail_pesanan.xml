<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/md_theme_surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detail Pesanan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/md_theme_primary"
        android:layout_marginBottom="16dp" />

    <!-- Details Grid -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="1"
        android:layout_marginBottom="16dp">

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                android:text="Tanggal"
                android:textColor="@color/md_theme_on_surface_variant"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />
            <TextView
                android:id="@+id/tv_detail_tanggal"
                android:text="29 Jun 2026"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_on_surface" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                android:text="Pelanggan"
                android:textColor="@color/md_theme_on_surface_variant"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />
            <TextView
                android:id="@+id/tv_detail_pelanggan"
                android:text="Nama Pelanggan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_on_surface" />
        </TableRow>

        <TableRow>
            <TextView
                android:text="Pembayaran"
                android:textColor="@color/md_theme_on_surface_variant"
                android:textSize="14sp"
                android:layout_marginEnd="16dp" />
            <TextView
                android:id="@+id/tv_detail_metode"
                android:text="Cash"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_on_surface" />
        </TableRow>
    </TableLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_theme_outline"
        android:layout_marginBottom="16dp" />

    <!-- Items Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Menu Yang Dipesan"
        android:textStyle="bold"
        android:textSize="15sp"
        android:textColor="@color/md_theme_primary"
        android:layout_marginBottom="8dp" />

    <!-- Dynamic Items Container -->
    <LinearLayout
        android:id="@+id/layout_detail_items_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp" />

    <!-- Total Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total Pembayaran"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/md_theme_on_surface" />
        <TextView
            android:id="@+id/tv_detail_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/color_income" />
    </LinearLayout>

    <!-- Catatan -->
    <TextView
        android:id="@+id/tv_detail_catatan_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catatan:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/md_theme_on_surface_variant"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_detail_catatan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catatan tambahan..."
        android:textSize="14sp"
        android:textColor="@color/md_theme_on_surface"
        android:layout_marginBottom="24dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Print -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_detail_print"
            style="@style/Widget.Material3.Button.ElevatedButton.Icon"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:icon="@drawable/ic_print"
            android:text="Cetak" />

        <!-- Edit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_detail_edit"
            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            app:icon="@drawable/ic_edit"
            android:text="Edit" />

        <!-- Delete -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_detail_delete"
            style="@style/Widget.Material3.Button.Icon"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:icon="@drawable/ic_delete"
            app:iconTint="@android:color/white"
            android:backgroundTint="@color/color_expense"
            android:textColor="@android:color/white"
            android:text="Hapus" />
    </LinearLayout>

</LinearLayout>
